# ---------------------------------------------------------------------------
# Database (MySQL — XAMPP lokal). Buat database `pakar_mojar` di phpMyAdmin
# sebelum menjalankan `pnpm drizzle-kit push`.
# ---------------------------------------------------------------------------
DATABASE_URL="mysql://root@localhost:3306/pakar_mojar"

# ---------------------------------------------------------------------------
# Auth.js v5 — secret untuk sign/verify session JWT.
# Generate: `openssl rand -base64 32`
# ---------------------------------------------------------------------------
AUTH_SECRET=""

# ---------------------------------------------------------------------------
# Gemini — API key fallback level aplikasi (opsional; user simpan key sendiri
# di Settings). Key valid berformat AIzaSy...
# ---------------------------------------------------------------------------
GEMINI_API_KEY=""

# ---------------------------------------------------------------------------
# Resend — pengiriman email notifikasi (approve/reject user).
# ---------------------------------------------------------------------------
RESEND_API_KEY=""

# ---------------------------------------------------------------------------
# Enkripsi AES-256 untuk API key Gemini milik user di tabel api_keys.
# Harus 32 byte. Generate: `openssl rand -hex 32`
# ---------------------------------------------------------------------------
ENCRYPTION_KEY=""
